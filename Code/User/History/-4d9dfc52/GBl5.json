{
    // Workspaces
    "hyprland/workspaces" : {
        "on-click": "activate",
        "active-only": false,
        "all-outputs": true,
        "format": "{}",
        "format-icons": {
			"urgent": "",
			"active": "",
			"default": ""
        },
        "persistent-workspaces": {
             "*": 5
        }       
    },

    // Hyprland Window
    "hyprland/window": {
        "separate-outputs": true
    },

    // Wofi Application Launcher
    "custom/appmenu": {
        "format": "οÄ² Apps",
        "tooltip-format": "Left: Open the application launcher",
        "on-click": "wofi -S drun",
        "tooltip": false
    },

    "battery":{
        "interval":30,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% σΑ²Ö",
        "format-plugged": "{capacity}% σΑ²Ö",
        "format-alt": "{time} {icon}",
        "format-icons": ["σΑ¹Κ", "σΑ¹Μ" , "σΑ¹Φ" , "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
    },
    
    // Power Menu
    "custom/exit": {
        "format": "βèΜ",
        "tooltip-format": "Powermenu",
        "on-click": "wlogout -b 3",
        "tooltip": false
    },

    // Keyboard State
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "οÄΘ",
            "unlocked": "ο²€"
        }
    },

    // System tray
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },

    // Clock
    "clock": {
        "format":"{:%I:%M}",
        "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },

    // System
    "custom/system": {
        "format": "νë≥",
        "tooltip": false
    },

    "custom/gpu":{
        "exec": "cat /sys/class/hwmon/hwmon2/device/gpu_busy_percent",
        "format": "/ σΑΔ° {}% ",
        "return-type": "",
        "interval": 1,
        "on-click": "kitty -e htop"
    },

    // CPU
    "cpu": {
        "format": "/ ο£Φ  {usage}% ",
        "on-click": "kitty -e htop"
    },

    // Memory
    "memory": {
        "format": "/ νΩÖ  {}% ",
        "on-click": "kitty -e htop"
    },

    // Harddisc space used
    "disk": {
        "interval": 30,
        "format": "D {percentage_used}% ",
        "path": "/",
        "on-click": "kitty -e htop"
    }, 

    "hyprland/language": {
        "format": "/ K {short}"
    },

    // Group Hardware
    "group/hardware": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 300,
            "children-class": "not-memory",
            "transition-left-to-right": false
        },        
        "modules": [
            "custom/system",
            "disk",
            "cpu",
            "custom/gpu",
            "memory",
            "hyprland/language"
        ]
    },
    
   // Network
    "network": {
        "format": "{ifname}",
        "format-wifi": "ο΅Ϊ  {signalStrength}%",
        "format-ethernet": "σΑàÄ {ifname}",
        "format-disconnected": "Not connected", //An empty format will hide the module.
        "tooltip-format": "οû• {ifname} via {gwaddri}",
        "tooltip-format-wifi": "ο΅Ϊ   {essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "οÉ¹  {ifname} ({ipaddr}/{cidr})",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50,
        "on-click": "kitty -e nmtui"
    },

    // Pulseaudio
    "pulseaudio": {
        "scroll-step": 1, // %, can be a float
        "format": "σΑ™É {volume}%",
        "format-bluetooth": "{volume}% {icon}οäî {format_source}",
        "format-bluetooth-muted": "οö© {icon}οäî {format_source}",
        "format-muted": " {format_source}",
        "format-source": "{volume}% ο³Α",
        "format-source-muted": "ο³±",
        "on-click": "pavucontrol"
    },

    // Bluetooth
    "bluetooth": {
        "format":" σΑ²·  ",
        "format-connected": " σΑ²±  ",
        "format-disabled": " σΑ²≤  ",
        "format-off": " σΑ²≤  ",
        "interval": 30,
        "on-click": "blueman-manager",
        "format-no-controller": ""
    },
    // Other
    "user": {
        "format": "{user}",
        "interval": 60,
        "icon": false,
    },

    // Idle Inhibator
    "idle_inhibitor": {
        "format": "{icon}",
        "tooltip": true,
        "format-icons":{
            "activated": "οè¹",
            "deactivated": "οÄΘ"
        },
        "on-click-right": "hyprlock"        
    }
}
