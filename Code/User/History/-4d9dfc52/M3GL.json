{
    // Workspaces
    "hyprland/workspaces" : {
        "on-click": "activate",
        "active-only": false,
        "all-outputs": true,
        "format": "{}",
        "format-icons": {
			"urgent": "",
			"active": "",
			"default": ""
        },
        "persistent-workspaces": {
             "*": 5
        }       
    },

    // Hyprland Window
    "hyprland/window": {
        "separate-outputs": true
    },

    // Wofi Application Launcher
    "custom/appmenu": {
        "format": "ï€‚ Apps",
        "tooltip-format": "Left: Open the application launcher",
        "on-click": "wofi -S drun",
        "tooltip": false
    },

    "battery":{
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% َ°‚…",
        "format-plugged": "{capacity}% َ°‚…",
        "format-alt": "{time} {icon}",
        "format-icons": ["َ°پ»", "َ°پ¼", "َ°پ¾", "َ°‚€", "َ°‚‚", "َ°پ¹"]
        
    },
    
    // Power Menu
    "custom/exit": {
        "format": "âڈ»",
        "tooltip-format": "Powermenu",
        "on-click": "wlogout -b 3",
        "tooltip": false
    },

    // Keyboard State
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "ï€£",
            "unlocked": "ï‚œ"
        }
    },

    // System tray
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },

    // Clock
    "clock": {
        "format":"{:%I:%M}",
        "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },

    // System
    "custom/system": {
        "format": "î‘³",
        "tooltip": false
    },

    "custom/gpu":{
        "exec": "cat /sys/class/hwmon/hwmon2/device/gpu_busy_percent",
        "format": "/ َ°¢® {}% ",
        "return-type": "",
        "interval": 1,
        "on-click": "kitty -e htop"
    },

    // CPU
    "cpu": {
        "format": "/ ï’¼  {usage}% ",
        "on-click": "kitty -e htop"
    },

    // Memory
    "memory": {
        "format": "/ î؟…  {}% ",
        "on-click": "kitty -e htop"
    },

    // Harddisc space used
    "disk": {
        "interval": 30,
        "format": "D {percentage_used}% ",
        "path": "/",
        "on-click": "kitty -e htop"
    }, 

    "hyprland/language": {
        "format": "/ K {short}"
    },

    // Group Hardware
    "group/hardware": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 300,
            "children-class": "not-memory",
            "transition-left-to-right": false
        },        
        "modules": [
            "custom/system",
            "disk",
            "cpu",
            "custom/gpu",
            "memory",
            "hyprland/language"
        ]
    },
    
   // Network
    "network": {
        "format": "{ifname}",
        "format-wifi": "ï‡«  {signalStrength}%",
        "format-ethernet": "َ°ˆ€ {ifname}",
        "format-disconnected": "Not connected", //An empty format will hide the module.
        "tooltip-format": "ï‍– {ifname} via {gwaddri}",
        "tooltip-format-wifi": "ï‡«   {essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "ïƒپ  {ifname} ({ipaddr}/{cidr})",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50,
        "on-click": "kitty -e nmtui"
    },

    // Pulseaudio
    "pulseaudio": {
        "scroll-step": 1, // %, can be a float
        "format": "َ°“ƒ {volume}%",
        "format-bluetooth": "{volume}% {icon}ïٹ” {format_source}",
        "format-bluetooth-muted": "ïڑ© {icon}ïٹ” {format_source}",
        "format-muted": " {format_source}",
        "format-source": "{volume}% ï„°",
        "format-source-muted": "ï„±",
        "on-click": "pwvucontrol"
    },

    // Bluetooth
    "bluetooth": {
        "format":" َ°‚¯  ",
        "format-connected": " َ°‚±  ",
        "format-disabled": " َ°‚²  ",
        "format-off": " َ°‚²  ",
        "interval": 30,
        "on-click": "blueman-manager",
        "format-no-controller": ""
    },
    // Other
    "user": {
        "format": "{user}",
        "interval": 60,
        "icon": false,
    },

    // Idle Inhibator
    "idle_inhibitor": {
        "format": "{icon}",
        "tooltip": true,
        "format-icons":{
            "activated": "ïڈپ",
            "deactivated": "ï€£"
        },
        "on-click-right": "hyprlock"        
    }
}
